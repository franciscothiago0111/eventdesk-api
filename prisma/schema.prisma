// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ORGANIZER
  STAFF
  ATTENDEE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
}

enum EventCategory {
  CONFERENCE
  WORKSHOP
  MEETUP
  HACKATHON
  WEBINAR
  TRAINING
  OTHER
}

enum EventImageType {
  PROFILE
  COVER
  GALLERY
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizedEvents   Event[]        @relation("OrganizerEvents")
  checkInsPerformed CheckIn[]      @relation("StaffCheckIns")
  notifications     Notification[]
}

model Event {
  id          String        @id @default(cuid())
  organizerId String
  organizer   User          @relation("OrganizerEvents", fields: [organizerId], references: [id])
  name        String
  description String?
  location    String?
  category    EventCategory @default(OTHER)
  passHash    String?
  startDate   DateTime
  endDate     DateTime
  capacity    Int
  status      EventStatus   @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  registrations Registration[]
  schedule      ScheduleItem[]
  images        EventImage[]

  @@index([organizerId])
}

model ScheduleItem {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId])
}

model EventImage {
  id        String         @id @default(cuid())
  eventId   String
  event     Event          @relation(fields: [eventId], references: [id])
  url       String
  key       String
  type      EventImageType
  caption   String?
  createdAt DateTime       @default(now())

  @@index([eventId])
  @@index([eventId, type])
}

model Registration {
  id            String             @id @default(cuid())
  eventId       String
  event         Event              @relation(fields: [eventId], references: [id])
  attendeeName  String
  attendeeEmail String
  checkInCode   String             @unique
  status        RegistrationStatus @default(CONFIRMED)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  checkIn CheckIn?

  @@index([eventId])
}

model CheckIn {
  id              String       @id @default(cuid())
  registrationId  String       @unique
  registration    Registration @relation(fields: [registrationId], references: [id])
  checkedInById   String
  checkedInBy     User         @relation("StaffCheckIns", fields: [checkedInById], references: [id])
  checkedInAt     DateTime     @default(now())
  fromOfflineSync Boolean      @default(false)

  @@index([checkedInById])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}
